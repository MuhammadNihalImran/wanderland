<% layout('/layouts/boilerplate.ejs') -%>

    <body>
        <div class="row mt-4">
            <div class="col-8 offset-2">
                <h2>Edit your Review</h2>
                <p class="text-muted">for <b>
                        <%= listing.title %>
                    </b></p>

                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT"
                    novalidate class="needs-validation">
                    <div class="mb-3 mt-3">
                        <fieldset class="starability-slot">
                            <legend>Rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                <%=review.rating===1 ? 'checked' : '' %> aria-label="No rating." />

                            <input type="radio" id="first-rate1" name="review[rating]" value="1" <%=review.rating===1
                                ? 'checked' : '' %> />
                            <label for="first-rate1" title="Terrible">1 star</label>

                            <input type="radio" id="first-rate2" name="review[rating]" value="2" <%=review.rating===2
                                ? 'checked' : '' %> />
                            <label for="first-rate2" title="Not good">2 stars</label>

                            <input type="radio" id="first-rate3" name="review[rating]" value="3" <%=review.rating===3
                                ? 'checked' : '' %> />
                            <label for="first-rate3" title="Average">3 stars</label>

                            <input type="radio" id="first-rate4" name="review[rating]" value="4" <%=review.rating===4
                                ? 'checked' : '' %> />
                            <label for="first-rate4" title="Very good">4 stars</label>

                            <input type="radio" id="first-rate5" name="review[rating]" value="5" <%=review.rating===5
                                ? 'checked' : '' %> />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>

                    <div class="mb-3 mt-3">
                        <label for="comment" class="form-label">Comment</label>
                        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                            required><%= review.comment %></textarea>
                        <div class="invalid-feedback">Please add some comment for your review.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark">Update Review</button>
                        <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </body>